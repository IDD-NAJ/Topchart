# ──────────────────────────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.production and fill in the actual production values
# DO NOT commit .env.production to version control

# ──────────────────────────────────────────────────────────────────────────────
# Google OAuth (NextAuth.js)
# ──────────────────────────────────────────────────────────────────────────────
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a new project or select existing
# 2. Enable "Google People API"
# 3. Go to Credentials → Create OAuth 2.0 Client ID
# 4. Add redirect URIs:
#    - Production: https://yourdomain.com/api/auth/callback/google
AUTH_SECRET=your-random-32-character-secret-key-here
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ──────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Use your production database connection string
# Recommended: Neon PostgreSQL or similar managed database
DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require

# Session Security
SESSION_SECRET=your-random-secret-key-change-this-in-production

# ──────────────────────────────────────────────────────────────────────────────
# Payment Processing
# ──────────────────────────────────────────────────────────────────────────────
# Use your live Paystack secret key for production
PAYSTACK_SECRET_KEY=sk_live_your-live-paystack-secret-key

# ──────────────────────────────────────────────────────────────────────────────
# Application Configuration
# ──────────────────────────────────────────────────────────────────────────────
# CRITICAL: Set this to your production domain (e.g., https://topchart.store)
# This is used for CSP headers, OAuth redirects, and cookie domain
NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# ──────────────────────────────────────────────────────────────────────────────
# Supabase Storage (Homepage media uploads)
# ──────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET_HOMEPAGE_MEDIA=homepage-media

# ──────────────────────────────────────────────────────────────────────────────
# Tawk.to Chat Configuration (Optional)
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TAWK_PROPERTY_ID=your-tawk-property-id
NEXT_PUBLIC_TAWK_WIDGET_ID=your-tawk-widget-id

# ──────────────────────────────────────────────────────────────────────────────
# Optional Analytics
# ──────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_URL=https://analytics.yourdomain.com
