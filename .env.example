# Database (at least one required)
DATABASE_URL=
NEON_DATABASE_URL=
NETLIFY_DATABASE_URL=

# Application
# IMPORTANT: Set this to your production domain in production environment
# Do not leave as localhost for production builds
NEXT_PUBLIC_APP_URL=https://topchart.store

# Paystack (required for payments)
PAYSTACK_SECRET_KEY=

# Supabase Storage (optional - for homepage media)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_HOMEPAGE_MEDIA=

# DataMart (required for data bundles)
DATAMART_API_KEY=
DATAMART_BASE_URL=
DATAMART_WEBHOOK_SECRET=
DATAMART_SIGNING_SECRET=
# NEXT_PUBLIC_DATAMART_API_KEY removed — do not expose API key to client bundle

# Hubnet (optional - fallback provider for data bundles)
HUBNET_API_KEY=
HUBNET_BASE_URL=
HUBNET_PURCHASE_PATH=
HUBNET_TIMEOUT_MS=

# PVAdeals (optional - for verification numbers)
PVADEALS_API_KEY=
PVADEALS_BASE_URL=
PVADEALS_MARKUP_PERCENT=
USD_TO_GHS_RATE=
NEXT_PUBLIC_USD_TO_GHS_RATE=

# Reloadly (optional - for airtime/data)
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=
RELOADLY_BASE_URL=
RELOADLY_API_BASE_URL=
RELOADLY_AUTH_URL=
RELOADLY_SANDBOX=false

# 9Proxy (optional - for proxies)
NINEPROXY_API_KEY=
NINEPROXY_BASE_URL=
NINEPROXY_SANDBOX=false

# Airalo (optional - for eSIM)
AIRALO_CLIENT_ID=
AIRALO_CLIENT_SECRET=
AIRALO_WEBHOOK_SECRET=
AIRALO_SANDBOX=false

# VTpass (optional - for bill payments)
VTPASS_API_KEY=
VTPASS_SECRET_KEY=
VTPASS_BASE_URL=
VTPASS_SANDBOX=false

# Google Auth (required for Google login)
# IMPORTANT: NEXT_PUBLIC_APP_URL must match your production domain exactly
# and must be configured in Google Cloud Console OAuth 2.0 Client ID settings
# 
# Local Development:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Add to Google Cloud Console: http://localhost:3000/api/auth/google/callback
#
# Production (example for topchart.store):
# NEXT_PUBLIC_APP_URL=https://topchart.store
# Add to Google Cloud Console: https://topchart.store/api/auth/google/callback
#
# If you get "redirect_uri_mismatch" error, check that:
# 1. NEXT_PUBLIC_APP_URL is set correctly in your hosting platform environment variables
# 2. The exact same URL is added as an authorized redirect URI in Google Cloud Console
# 3. Protocol matches (http vs https)
# 4. No trailing slashes in the redirect URI
AUTH_GOOGLE_ID=134593970079-t68868p7lq6vdn66tf9ok5hi0364fc03.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=
AUTH_SECRET=

# WhatsApp (optional)
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_ENABLED=true

# Tawk.to Chat (optional)
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=
NEXT_PUBLIC_TAWK_ENABLED=true

# Email (optional)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Cron Secret (optional)
CRON_SECRET=
