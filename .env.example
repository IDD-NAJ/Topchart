# Database Configuration
# Get connection string from your Neon dashboard at https://console.neon.tech
DATABASE_URL=postgresql://username:password@hostname/database
NEON_DATABASE_URL=postgresql://username:password@hostname/database
NETLIFY_DATABASE_URL=postgresql://username:password@hostname/database
NEXT_PUBLIC_DATABASE_URL=postgresql://username:password@hostname/database

# Session Security
SESSION_SECRET=your-random-secret-key-change-this-in-production

# Payment Processing (Test Mode - replace with live key for production)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Exchange Rate Configuration
NEXT_PUBLIC_USD_TO_GHS_RATE=15.5

# Tawk.to Chat Configuration
NEXT_PUBLIC_TAWK_PROPERTY_ID=your-tawk-property-id
NEXT_PUBLIC_TAWK_WIDGET_ID=your-tawk-widget-id

# PVADeals API Configuration (for verification services)
PVADEALS_API_KEY=your-pvadeals-api-key

# Optional Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id

# Textverified API Configuration (for phone number verification services)
# Get your API key from https://textverified.com
TEXTVERIFIED_API_KEY=your-textverified-api-key
TEXTVERIFIED_API_URL=https://api.textverified.com
TEXTVERIFIED_WEBHOOK_SECRET=your_webhook_secret_for_signature_verification

# Reloadly Gift Card API Configuration
# Get your credentials from https://dashboard.reloadly.com
RELOADLY_CLIENT_ID=your-reloadly-client-id
RELOADLY_CLIENT_SECRET=your-reloadly-client-secret
RELOADLY_API_BASE_URL=https://giftcards.reloadly.com
RELOADLY_SANDBOX=true
DEFAULT_GIFTCARD_MARKUP=40
