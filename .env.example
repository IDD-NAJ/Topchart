# Database Configuration
# Get connection string from your Neon dashboard at https://console.neon.tech
DATABASE_URL=postgresql://username:password@hostname/database

# Session Security
SESSION_SECRET=your-random-secret-key-change-this-in-production

# Payment Processing (Test Mode - replace with live key for production)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id
